# Copy to .env.local and fill in.
# Find these in your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Required for admin operations (e.g., creating sessions on behalf of students).
# NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used to sign short-lived session tokens for students taking a test.
# Any random 32+ char string. Generate with: openssl rand -hex 32
SESSION_SIGNING_SECRET=replace-me-with-a-long-random-string

# Optional: lock teacher signups to your school's email domain.
# Comma-separated. Leave blank to allow any domain.
ALLOWED_TEACHER_EMAIL_DOMAINS=
