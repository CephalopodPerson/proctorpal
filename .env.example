# Copy to .env.local and fill in.
# Find these in your Supabase project: Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Publishable key (starts with `sb_publishable_`). Safe for the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# Secret key (starts with `sb_secret_`). Server-only — bypasses RLS.
# NEVER expose this to the client or commit it to git.
SUPABASE_SECRET_KEY=sb_secret_xxxxx

# Used to sign short-lived session tokens for students taking a test.
# Any random 32+ char string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SIGNING_SECRET=replace-me-with-a-long-random-string

# Set to your deployed URL (used by the logout redirect).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: lock teacher signups to your school's email domain.
# Comma-separated. Leave blank to allow any domain.
ALLOWED_TEACHER_EMAIL_DOMAINS=

# Set to "false" to lock teacher signups (invite-only). When false, /signup
# shows a notice and you must add teachers via Supabase dashboard.
NEXT_PUBLIC_ALLOW_TEACHER_SIGNUPS=true
